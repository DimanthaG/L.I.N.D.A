NODE_ENV=development
PORT=3001

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=linda

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# Reddit API
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:3001/auth/reddit/callback
REDDIT_USER_AGENT=LINDA/1.0 by YourRedditUsername

# Rate Limiting
REDDIT_RATE_LIMIT_CALLS=60
REDDIT_RATE_LIMIT_PERIOD=60000

# Background Jobs
SYNC_JOB_INTERVAL=900000
ANALYSIS_JOB_CONCURRENCY=5
STRATEGY_JOB_INTERVAL=3600000

# Logging
LOG_LEVEL=info
